# 총 자산 (KRW). 기본 5,000만원.
TOTAL_CAPITAL=50000000

# 대시보드 공개 URL (HTML 푸터·잔디 메시지에 표기)
DASHBOARD_PUBLIC_URL=https://daewon82.github.io/trading/

# 잔디 incoming webhook URL (액션 신호 발생 시 알림)
# 잔디 설정 → 커넥트 → Incoming Webhook
JANDI_WEBHOOK_URL=https://wh.jandi.com/connect-api/webhook/YOUR_ID/YOUR_TOKEN

# 1로 설정하면 실제 발송 없이 payload만 로그 출력
# JANDI_DRY_RUN=1

# 보유 종목 (선택) — 파일 대신 환경변수로 주입 가능
# HOLDINGS_JSON=[{"code":"005930","name":"삼성전자","buyPrice":80000,"quantity":41,"buyDate":"2026-05-01"}]

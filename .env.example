# v1.7 — 잔디 강력매수 알림 환경변수 (CLAUDE.md §4.9)
# 실제 값은 .env에 저장하고 절대 git에 커밋하지 말 것

# 잔디 incoming webhook URL (잔디 설정 → 커넥트 → Incoming Webhook 생성)
JANDI_WEBHOOK_URL=https://wh.jandi.com/connect-api/webhook/YOUR_ID/YOUR_TOKEN

# 대시보드 공개 URL (알림 메시지 하단에 첨부)
DASHBOARD_PUBLIC_URL=https://daewon82.github.io/trading/

# 1로 설정하면 실제 발송 없이 로그만 출력
# JANDI_DRY_RUN=1

# 보유 종목 손익 추적 (HoldingPosition[] JSON)
# 매수가·수량·매수일을 직접 입력 (CLAUDE.md §4.8)
# HOLDINGS_JSON=[{"code":"005930","name":"삼성전자","buyPrice":280000,"quantity":2,"buyDate":"2026-05-01"}]
